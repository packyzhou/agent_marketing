      "Bash(docker-compose down:*)",
      "Bash(docker pull:*)",
      "Bash(curl -s http://localhost:8000/)",
      "Bash(docker-compose logs:*)",
      "Bash(docker exec:*)",
      "Bash(curl -s -X POST http://localhost:8000/api/auth/login -H 'Content-Type: application/json' -d '{\"username\":\"admin\",\"password\":\"admin123\"}')",
      "Bash(curl -s -I -X GET \"http://localhost:8000/api/user/providers\" -H \"Authorization: Bearer $\\(curl -s -X POST http://localhost:8000/api/auth/login -H 'Content-Type: application/json' -d '{\"username\":\"admin\",\"password\":\"admin123\"}')",
